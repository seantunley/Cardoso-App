SESSION_SECRET=change-me-to-a-long-random-string
DB_PATH=./database/cardoso.db
PORT=3001

# AES-256-GCM encryption key for MSSQL connection passwords (recommended)
# Generate on Linux/Mac: openssl rand -hex 32
# Generate on Windows PowerShell: -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
# Must be exactly 64 hex characters (32 bytes). Leave unset to store passwords as plaintext.
ENCRYPTION_KEY=

# Development only (not needed in production)
# FRONTEND_ORIGIN=http://localhost:5173

# Set to "production" when running as a service
# NODE_ENV=production
